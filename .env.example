# Ververica Cloud credentials for integration testing
# Copy to .env and fill in real values. NEVER commit .env to git.

VERVERICA_EMAIL=your-email@example.com
VERVERICA_PASSWORD=your-password-here
VERVERICA_GATEWAY_URL=https://app.ververica.cloud
VERVERICA_WORKSPACE_ID=your-workspace-uuid-here
VERVERICA_NAMESPACE=default
VERVERICA_ENGINE_VERSION=vera-4.0.0-flink-1.20
