# dbt-flink-ververica Configuration File
#
# This is an example configuration file. Copy this to dbt-flink-ververica.toml
# and customize for your project.
#
# You can also generate a default config with:
#   dbt-flink-ververica config init

[ververica]
# Ververica Cloud gateway URL
gateway_url = "https://app.ververica.cloud"

# Your workspace ID (find in Ververica Cloud UI)
# This is required for deployments
workspace_id = "your-workspace-id-here"

# Namespace within the workspace
namespace = "default"

# Default Flink engine version
# Options: "vera-4.0.0-flink-1.20", "vera-3.0.0-flink-1.19", etc.
default_engine_version = "vera-4.0.0-flink-1.20"


[dbt]
# Path to your dbt project
# Use "." for current directory
project_dir = "."

# Path to dbt profiles directory
# Leave commented to use default (~/.dbt)
# profiles_dir = "/path/to/profiles"

# dbt target to use for compilation
target = "prod"

# Specific models to compile (empty = all models)
# models = ["my_model", "staging.*"]
models = []


[deployment]
# Default deployment name
# Can be overridden with --name flag
deployment_name = "my-flink-job"

# Job parallelism (number of parallel tasks)
parallelism = 2

# Engine version for this deployment (overrides ververica.default_engine_version)
# engine_version = "vera-4.0.0-flink-1.20"

# Restore strategy for stateful upgrades
# Options: LATEST_STATE, LATEST_SAVEPOINT, NONE
restore_strategy = "LATEST_STATE"

# Upgrade strategy
# Options: STATEFUL, STATELESS
upgrade_strategy = "STATEFUL"

# Additional Flink configuration
[deployment.flink_config]
# Checkpointing
"execution.checkpointing.interval" = "60s"
"execution.checkpointing.mode" = "EXACTLY_ONCE"
"execution.checkpointing.timeout" = "10min"

# State backend
"state.backend" = "rocksdb"
"state.backend.incremental" = "true"

# Restart strategy
"restart-strategy" = "fixed-delay"
"restart-strategy.fixed-delay.attempts" = "3"
"restart-strategy.fixed-delay.delay" = "10s"

# Memory configuration
"taskmanager.memory.process.size" = "4gb"
"taskmanager.memory.managed.fraction" = "0.4"

# Tags for the deployment
[deployment.tags]
environment = "production"
team = "data-platform"
owner = "your-team@example.com"
cost-center = "engineering"


[sql_processing]
# Strip dbt-flink query hints (/** hint_name('value') */)
strip_hints = true

# Generate SET statements from query hints
generate_set_statements = true

# Wrap multiple statements in STATEMENT SET
# (usually false for Ververica Cloud)
wrap_in_statement_set = false

# Include DROP statements from drop_statement hint
include_drop_statements = true


# Example configurations for different environments:

# Development environment
# [ververica]
# workspace_id = "dev-workspace-id"
# namespace = "dev"
#
# [dbt]
# target = "dev"
#
# [deployment]
# deployment_name = "my-job-dev"
# parallelism = 1
#
# [deployment.tags]
# environment = "development"


# Staging environment
# [ververica]
# workspace_id = "staging-workspace-id"
# namespace = "staging"
#
# [dbt]
# target = "staging"
#
# [deployment]
# deployment_name = "my-job-staging"
# parallelism = 2
# restore_strategy = "LATEST_SAVEPOINT"
#
# [deployment.tags]
# environment = "staging"


# Production environment
# [ververica]
# workspace_id = "prod-workspace-id"
# namespace = "production"
#
# [dbt]
# target = "prod"
#
# [deployment]
# deployment_name = "my-job-prod"
# parallelism = 4
# restore_strategy = "LATEST_STATE"
# upgrade_strategy = "STATEFUL"
#
# [deployment.flink_config]
# "execution.checkpointing.interval" = "30s"
# "taskmanager.memory.process.size" = "8gb"
#
# [deployment.tags]
# environment = "production"
# sla = "critical"
